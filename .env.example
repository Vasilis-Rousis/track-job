# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobtracker

# JWT
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# Backend
PORT=3000
NODE_ENV=development

# Frontend (Vite requires VITE_ prefix)
VITE_API_BASE_URL=http://localhost:3000/api

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# CORS - frontend origin
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://redis:6379

# Encryption key for Gmail tokens (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Google OAuth2 (Gmail) — create at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Admin (for seed script and notification emails)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
