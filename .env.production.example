# Database
DATABASE_URL=postgresql://jobtracker_user:STRONG_PASSWORD_HERE@db:5432/jobtracker
POSTGRES_USER=jobtracker_user
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_STRING_HERE
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com
VITE_API_BASE_URL=https://yourdomain.com/api

# Redis
REDIS_URL=redis://redis:6379

# Google OAuth2 (Gmail) — update redirect URI to production domain
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/gmail/callback

# Admin (used by seed script and notification emails)
ADMIN_EMAIL=your_email@gmail.com
ADMIN_PASSWORD=your_secure_password
ADMIN_NAME=Your Name

# Caddy domain (used in Caddyfile)
DOMAIN=yourdomain.com
